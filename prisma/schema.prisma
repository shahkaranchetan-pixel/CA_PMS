generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Role is stored as plain String in DB (ADMIN | EMPLOYEE) to avoid PostgreSQL enum migration issues

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("EMPLOYEE")
  dept          String    @default("GST")
  color         String    @default("#4FACFE")
  phone         String?
  accounts      Account[]
  sessions      Session[]
  taskAssignees TaskAssignee[]
  clientNotes   ClientNote[]
  taskLogs      TaskLog[]
  notifications Notification[]
  vaultAuditLogs VaultAuditLog[]
  trainingProgress UserTrainingProgress[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ... (existing code)

model TrainingModule {
  id          String             @id @default(cuid())
  title       String
  description String?
  category    String             // e.g., 'Excel', 'Tally', 'Income Tax', 'GST'
  order       Int                @default(0)
  materials   TrainingMaterial[]
  progress    UserTrainingProgress[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([category])
}

model TrainingMaterial {
  id          String         @id @default(cuid())
  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  type        String         // 'TEXT', 'LINK', 'VIDEO_EMBED'
  content     String         // Markdown text, URL, or Embed code
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([moduleId])
}

model UserTrainingProgress {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  completed   Boolean        @default(false)
  score       Int?
  attemptCount Int           @default(0)
  lastViewed  DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, moduleId])
}


model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id           String   @id @default(cuid())
  name         String
  entityType   String   @default("Proprietorship")
  gstCategory  String   @default("MONTHLY") // MONTHLY, QUARTERLY, EXEMPT
  active       Boolean  @default(true)
  gstin        String?
  pan          String?
  tan          String?
  contactPerson String?
  contactEmail  String?
  contactPhone  String?
  
  // Login Credentials - Standard Portals
  itxLogin     String?   
  itxPassword  String?
  gstLogin     String?   
  gstPassword  String?
  tracesLogin  String?   
  tracesPassword String?
  // Separate PF, ESI, PT
  pfLogin      String?
  pfPassword   String?
  esiLogin     String?
  esiPassword  String?
  ptLogin      String?   
  ptPassword   String?

  tasks        Task[]
  notes        ClientNote[]
  vaultEntries ClientVaultEntry[]
  documents    ClientDocument[]
  vaultAuditLogs VaultAuditLog[]
  
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([deletedAt])
  @@index([active, deletedAt])
}

model ClientVaultEntry {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  portalName  String
  username    String?
  password    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
}

model ClientDocument {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category    String   // PAN, TAN, GST_CERT, PARTNER_KYC, DIRECTOR_KYC, COI, MOA, AOA, OTHER
  fileName    String
  filePath    String
  fileSize    Int?
  mimeType    String?
  notes       String?
  uploadedAt  DateTime @default(now())

  @@index([clientId])
}

model Task {
  id          String   @id @default(cuid())
  title       String   
  taskType    String   
  description String?
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, BLOCKED, UNDER_REVIEW
  priority    String   @default("medium") // high, medium, low
  frequency   String   @default("ONCE") // ONCE, DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  dueDate     DateTime?
  period      String?  
  timeLogged  Int      @default(0) // time logged in minutes
  estimatedMinutes Int?
  isCustom    Boolean  @default(false)

  deletedAt   DateTime?
  color       String?
  icon        String?
  month       Int?
  year        Int?
  dueDay      Int?
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  
  taskAssignees TaskAssignee[]

  parentId    String?
  parent      Task?    @relation("TaskToSubtasks", fields: [parentId], references: [id])
  subtasks    Task[]   @relation("TaskToSubtasks")

  blockedById String?
  blockedBy   Task?    @relation("TaskDependencies", fields: [blockedById], references: [id])
  blocking    Task[]   @relation("TaskDependencies")

  activities  Activity[]
  logs        TaskLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([deletedAt])
  @@index([status])
  @@index([dueDate])
  @@index([clientId])
  @@index([period])
  @@index([parentId])
  @@index([taskType])
  @@index([status, deletedAt])
  @@index([clientId, period, taskType])
  @@index([createdAt])
}

model Activity {
  id          String   @id @default(cuid())
  title       String   
  isCompleted Boolean  @default(false)
  
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([taskId])
}

model TaskLog {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String   // The comment or activity description
  type        String   @default("COMMENT") // COMMENT, STATUS_CHANGE
  oldStatus   String?
  newStatus   String?
  createdAt   DateTime @default(now())

  @@index([taskId])
  @@index([createdAt])
}



model ClientNote {
  id          String   @id @default(cuid())
  type        String
  text        String
  date        DateTime @default(now())

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])

  @@index([clientId])
}

model Reminder {
  id          String   @id @default(cuid())
  taskType    String
  channel     String
  trigger     String
  enabled     Boolean  @default(true)
  message     String
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  items       TaskTemplateItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskTemplateItem {
  id             String   @id @default(cuid())
  title          String
  taskType       String
  description    String?
  priority       String   @default("medium")
  dueDayOffset   Int      @default(0) // Days from template application date
  
  templateId     String
  template       TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
  @@index([taskId])
}

model VaultAuditLog {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  portalName  String   // e.g. 'Income Tax Portal', 'PF (EPFO)', or custom portal name
  action      String   // VIEW, COPY
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}
